# =============================================================================
# 仅云 MySQL（复制为 .env 后填写，勿提交 .env）
# =============================================================================
# 必填：DATABASE_MODE=mysql + 下面 HOST/USER/PASSWORD/NAME。
# 拉数 / API / init_db 都会读同一套配置；请用「数据写入目标」日志核对是否连对库。
#
# 1) 云上执行：CREATE DATABASE trading CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# 2) 账号「主机」：你的公网 IP 或 %（按云控制台要求）
# 3) 安全组放行数据库端口（如 3306），来源尽量只放开你本机公网 IP
# 4) 连不上或 RDS 要求加密：DATABASE_SSL=true（阿里云/腾讯云 RDS 常见）
#
# 本地 SQLite（DATABASE_MODE=sqlite）时可用：库文件路径（相对项目根或绝对路径）
# DATABASE_SQLITE_PATH=data/trading.db

DATABASE_MODE=mysql

# 云实例地址：控制台「外网地址」或绑定的域名（不要用 127.0.0.1，除非本机 SSH 隧道）
DATABASE_HOST=your-mysql-host.example.com
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=your_secure_password
DATABASE_NAME=trading

DATABASE_CONNECT_TIMEOUT=30
DATABASE_SSL=false

# =============================================================================
# Redis（可选；不用可保持 false）
# =============================================================================
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# 异步回测 job：auto=随 REDIS_ENABLED 用 Redis 队列+持久化；memory=始终进程内；redis=强制 Redis（未连上则 POST 异步 503）
# BACKTEST_ASYNC_JOB_STORE=auto
# Redis 中任务 JSON 过期秒数（默认 7 天）
# BACKTEST_ASYNC_JOB_TTL_SEC=604800
# running 超过该秒数未结束时，GET /api/backtest/jobs/{id} 可置为 failed（默认 1800；0 关闭）
# BACKTEST_ASYNC_JOB_STUCK_SEC=1800

DATA_SOURCE=baostock

# 交易日历：看板「分区」下拉与 GET /api/data/trade-calendar/options（逗号分隔 exchange）
# TRADE_CALENDAR_EXCHANGE_OPTIONS=cn,hk,us
# TRADE_CALENDAR_DEFAULT_EXCHANGE=cn

LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
# 生产前端跨域：逗号分隔，如 https://app.example.com（开发可留空或 *）
# CORS_ORIGINS=*

# 实时行情 /api/realtime/*：短缓存（秒）与每 IP 每分钟请求上限
# REALTIME_CACHE_TTL_SEC=15
# REALTIME_RATE_PER_MINUTE=60

# =============================================================================
# 提示（本段不是「后端会读取」的变量名，仅说明联调）
# =============================================================================
# Vue 看板：`cd frontend && npm run dev`，经 Vite 把 /api 代理到本机 FastAPI（默认 8000）。
# 前端环境变量示例见 **frontend/.env.example**（如 VITE_PROXY_TARGET）。
# 看板 JSON：涨跌榜 `GET /api/dashboard/gainers`、`/losers`；成交额 `GET /api/dashboard/turnover`（可选 `trade_date`、`limit`）。
# 接口总览：启动 API 后打开 /docs；栈探测：`python scripts/verify_stack.py`（支持 mysql / sqlite）。
