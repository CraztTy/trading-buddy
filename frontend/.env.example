# 开发环境：可复制为 `.env.development`（或在本机合并进现有文件）
# Vite 会读取；见根目录 `frontend/vite.config.js` 中 `loadEnv` / 代理配置。

# 留空则走同源 `/api`（由 dev server 代理到后端）
VITE_API_BASE=

# 代理目标：本机 FastAPI 默认 http://127.0.0.1:8000
VITE_PROXY_TARGET=http://127.0.0.1:8000

# 看板「交易日历」下拉的 exchange 列表来自后端环境变量（非 Vite 读取）：
# 根目录 .env 中 TRADE_CALENDAR_EXCHANGE_OPTIONS / TRADE_CALENDAR_DEFAULT_EXCHANGE
# 对应 GET /api/data/trade-calendar/options

# Playwright E2E：在运行 `npm run test:e2e` 的 shell 中导出（非 Vite 读取）。默认 http://127.0.0.1:4173
#
# 方式 B（双终端，推荐）：终端一 npm run e2e:preview（或 dist 已新时用 e2e:preview:only）；终端二 npm run test:e2e:connected（内置 PLAYWRIGHT_BASE_URL）。快速冒烟：npm run test:e2e:smoke:connected
#   Playwright UI：npm run test:e2e:ui:connected
#   亦可手写（与 connected 等价）：
#     $env:PLAYWRIGHT_BASE_URL = "http://127.0.0.1:4173"
#     $env:PLAYWRIGHT_EXECUTABLE_PATH = "D:\\path\\to\\chrome-win64\\chrome.exe"   # 可选
#     npm run test:e2e
# 方式 A（单终端）：不要导出 PLAYWRIGHT_BASE_URL，由 playwright.config 内置 webServer 起 4173。
#   无头：npm run test:e2e；UI：npm run test:e2e:ui；UI+通道：test:e2e:ui:chromium / :ui:chrome（均可加 -- e2e/某.spec.js）
#
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
# 手动下载 Chrome for Testing 的 chrome-win64.zip：先解压，再设下面为 chrome.exe 绝对路径（优先于 channel / 内置 Chromium）。
# 常见布局：…\chrome-win64\chrome.exe；部分压缩包多一层 …\chrome-win64\chrome-win64\chrome.exe
# PLAYWRIGHT_EXECUTABLE_PATH=D:\\谷歌浏览器下载\\chrome-win64\\chrome-win64\\chrome.exe
# Windows：若已 npx playwright install chromium，playwright.config 默认优先内置 Chromium；强制系统 Chrome：PLAYWRIGHT_CHANNEL=chrome
# macOS/Linux 要用系统 Chrome：PLAYWRIGHT_CHANNEL=chrome；强制自带 Chromium：PLAYWRIGHT_CHANNEL=chromium
# 或在 frontend：npm run test:e2e:chromium / test:e2e:chrome（方式 A）；test:e2e:connected:chromium / :connected:chrome（方式 B）；子集加 -- e2e/某.spec.js
